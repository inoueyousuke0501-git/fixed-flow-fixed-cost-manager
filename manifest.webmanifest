{
  "name": "Fixed Flow - 固定費管理",
  "short_name": "Fixed Flow",
  "description": "毎月・毎年の固定費を一覧、集計、カレンダーで管理するPWAアプリ",
  "start_url": "./",
  "scope": "./",
  "display": "standalone",
